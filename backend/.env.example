# Copy to `.env` (gitignored) and fill real values. NEVER commit a populated .env.

# Runtime
ENV=dev

# Database — async DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://dc:dc@localhost:5432/dc_motorshop

# Auth / JWT — generate a strong secret, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Redis — rate limiting + refresh-token reuse detection
REDIS_URL=redis://localhost:6379/0

# S3-compatible object storage (product/logo images)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dc-motorshop
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# CORS — comma-separated origin allowlist (empty = deny all browsers; mobile sends no Origin)
CORS_ALLOW_ORIGINS=
